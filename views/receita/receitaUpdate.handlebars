<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h3>Editar Receita</h3>
            <form action="/receitaUpdate" method="post">
                <input type="hidden" name="id" value={{receita.id}}>
                Nome: <input type="text" name="nome" value="{{receita.nome}}">
                <br><br>
                Ingredientes: <input type="text" name="ingredientes" value="{{receita.ingredientes}}">
                <br><br>
                Preparo: <input type="text" name="preparo" value="{{receita.preparo}}">
                <br><br>
                Categoria:
                <select name="categoriaId">
                    {{#each categorias}}
                    <tr>
                        <option value={{nome}}>{{nome}}</option>
                    </tr>
                    {{/each}}
                </select>
                <br><br>
                Imagem: <input type="file" class="form-control" id="inputImagem" name="imagem">
                <br><br>
                <input type="submit" value="Editar">
            </form>
        </div>
    </div>
</div>